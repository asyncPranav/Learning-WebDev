<!DOCTYPE html>
<html>
<head>
  <title>404 - Not Found</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100 flex items-center justify-center min-h-screen">

  <div class="bg-white p-8 rounded shadow text-center max-w-md">

    <h1 class="text-4xl font-bold text-yellow-500">404</h1>

    <h2 class="text-xl font-semibold mt-2">Page Not Found</h2>

    <p class="text-gray-600 mt-2">
      <%= message || "The requested resource was not found" %>
    </p>

    <a href="/" class="mt-4 inline-block bg-blue-500 text-white px-4 py-2 rounded">
      Go Home
    </a>

  </div>

</body>
</html>
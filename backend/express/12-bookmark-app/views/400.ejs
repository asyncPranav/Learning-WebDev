<%- include("partials/header") %>

  <main class="flex-1 flex items-center justify-center">
    <div class="text-center px-4 py-20">

      <!-- Code -->
      <div class="mb-6">
        <span class="font-semibold tabular-nums" style="font-size:72px; line-height:1; color:#1e1e20; letter-spacing:-4px;">400</span>
      </div>

      <!-- Icon -->
      <div class="w-11 h-11 rounded-xl mx-auto mb-5 flex items-center justify-center" style="background:#2a2217;">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
          <path d="M9 3L9 10" stroke="#c4924a" stroke-width="1.5" stroke-linecap="round"/>
          <circle cx="9" cy="13.5" r="0.75" fill="#c4924a"/>
          <circle cx="9" cy="9" r="7.25" stroke="#c4924a" stroke-width="1.5"/>
        </svg>
      </div>

      <h1 class="text-sm font-semibold mb-1" style="color:#e2e2e0;">
        <% if (typeof message !== 'undefined' && message) { %>
          <%= message %>
        <% } else { %>
          Bad request
        <% } %>
      </h1>

      <p class="text-xs mb-7 max-w-xs mx-auto" style="color:#4b4b52; line-height:1.7;">
        The request could not be understood by the server. Check the URL and try again.
      </p>

      <a href="/"
        class="btn-primary inline-flex items-center gap-1.5 text-xs px-4 py-2 rounded-lg no-underline">
        <svg width="11" height="11" viewBox="0 0 12 12" fill="none">
          <path d="M7.5 2L3.5 6L7.5 10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        back to links
      </a>

    </div>
  </main>

<%- include("partials/footer") %>

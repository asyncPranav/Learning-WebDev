<%- include("partials/header") %>

<div class="flex flex-col items-center justify-center text-center min-h-[70vh]">

  <!-- 500 Text -->

  <h1 class="text-5xl sm:text-6xl font-bold tracking-tight text-[#f0f0f2] mb-3">
    500
  </h1>
  <% if(typeof message !=="undefined" ) { %>
    <h2 class="text-lg sm:text-xl font-medium text-[#f0f0f2] mb-2">
      <%= message %>
    </h2>
    <% } else { %>
      <h2 class="text-lg sm:text-xl font-medium text-[#f0f0f2] mb-2">
        Internal Server Error
      </h2>
  <% } %>

  <p class="text-sm text-[#6e6e7a] max-w-md mb-6 leading-relaxed">
    We ran into an unexpected error. It’s on us — please try again in a moment.
  </p>

  <!-- Actions -->
  <div class="flex items-center gap-3">

    <a href="/"
      class="text-sm font-medium text-[#191919] bg-[#4ade80] border border-[#4ade80]/40 px-5 py-2 rounded-lg hover:opacity-90 transition-all no-underline">
      <i class="fa-solid fa-house mr-1"></i> Go Home
    </a>

    <button onclick="location.reload()"
      class="text-sm font-medium text-[#6e6e7a] px-5 py-2 rounded-lg border border-white/[0.08] hover:text-[#f0f0f2] hover:border-white/[0.15] transition-all">
      <i class="fa-solid fa-rotate mr-1"></i> Retry
    </button>

  </div>

</div>

<%- include("partials/footer") %>